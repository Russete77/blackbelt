# Supabase — BLACK BELT 360
# Copie este arquivo para .env.local e preencha com os valores reais (nunca commitar .env.local).

# Públicas (expostas ao browser — a proteção real é o RLS)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloque-a-anon-key-aqui

# SECRETA — server-only, nunca no bundle do navegador (bypassa RLS)
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui

# Senha do banco — server-only (aplicar migrations via supabase db push / psql)
SUPABASE_DB_PASSWORD=coloque-a-senha-do-banco-aqui

# YouTube Data API v3 — server-only
YOUTUBE_API_KEY=coloque-a-youtube-api-key-aqui

# Worker Demucs (Railway) — server-only
DEMUCS_WORKER_URL=https://seu-worker.up.railway.app
DEMUCS_WORKER_SECRET=coloque-o-secret-do-worker-aqui
